rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Projects collection
    match /projects/{projectId} {
      allow read: if true;  // Anyone can read projects
      allow write: if request.auth != null;  // Only authenticated users can write
    }
    
    // Services collection
    match /services/{serviceId} {
      allow read: if true;  // Anyone can read services
      allow write: if request.auth != null;  // Only authenticated users can write
    }
    
    // Founders collection
    match /founders/{founderId} {
      allow read: if true;  // Anyone can read founder info
      allow write: if request.auth != null;  // Only authenticated users can write
    }
    
    // Comments collection
    match /comments/{commentId} {
      allow read: if true;  // Anyone can read comments
      allow create: if true;  // Anyone can create comments
      allow update, delete: if request.auth != null;  // Only authenticated users can modify or delete
    }
    
    // Contact messages collection
    match /contact/{messageId} {
      allow read: if request.auth != null;  // Only authenticated users can read messages
      allow create: if true;  // Anyone can send contact messages
      allow update, delete: if request.auth != null;  // Only authenticated users can modify or delete
    }
    
    // Ads collection
    match /ads/{adId} {
      allow read: if true;  // Anyone can read ads
      allow write: if request.auth != null;  // Only authenticated users can write
    }
  }
}
